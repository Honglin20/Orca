{
  "name": "orca-web-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Orca web SPA skeleton — react-router navigation + Zustand single store + lazy loading + WS hook (phase 9b)",
  "scripts": {
    "dev": "vite",
    "gen:events": "python ../../../../scripts/gen_events_ts.py",
    "prebuild": "python ../../../../scripts/gen_events_ts.py --check",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@types/prismjs": "^1.26.6",
    "@xyflow/react": "^12.11.1",
    "immer": "^11.1.8",
    "katex": "^0.17.0",
    "prismjs": "^1.30.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.7",
    "react-router-dom": "^6.28.0",
    "react-window": "^2.2.7",
    "recharts": "^3.9.1",
    "rehype-katex": "^7.0.1",
    "rehype-prism-plus": "^2.0.2",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^15.11.7",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^3.0.0"
  }
}
