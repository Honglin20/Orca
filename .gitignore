# External reference repos (read-only design references, not Orca code).
# 锚定根目录：只忽略 <repo-root>/references/（外部只读参考），不要误伤
# workflows/agents/<agent>/references/（folder-agent 的 skill 资源——速查/模板/checklist，
# 是 agent 的核心交付物，必须跟踪）。
/references/

# Codegraph local index
.codegraph/

# Runtime tape output (orca run/serve 写入)
runs/

# 本地第三方 skill 安装产物（如 fireworks-tech-graph），跨机器不可移植
.agents/
skills-lock.json

# workflows/ = 内置 workflow 源（随包版本化；teams install 部署到 ~/.orca/workflows 全局可见）。
# 项目级 workflow 放各自项目的 ./workflows（该项目自己的 gitignore 管）。

# 本地 E2E scratch 脚本（test-agent 一次性验证，硬编码本机路径）
e2e_check.sh
e2e_clean.sh
